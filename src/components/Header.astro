---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">
			<span class="logo-bracket">[</span>
			{SITE_TITLE}
			<span class="logo-bracket">]</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/guias">Guías</HeaderLink>
			<HeaderLink href="/about">Sobre mí</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/andrewdevweb" target="_blank" title="GitHub">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: rgba(10, 10, 15, 0.95);
		border-bottom: 1px solid #1e1e2e;
		position: sticky;
		top: 0;
		z-index: 100;
		backdrop-filter: blur(10px);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 760px;
		margin: 0 auto;
		height: 60px;
	}

	.logo {
		font-family: 'JetBrains Mono', monospace;
		font-size: 1em;
		white-space: nowrap;
		font-weight: 700;
		color: #e8eaf0;
		text-decoration: none;
		border-bottom: none;
		letter-spacing: 1px;
	}

	.logo:hover { border-bottom: none; }

	.logo-bracket {
		color: #00ff9f;
	}

	.internal-links {
		display: flex;
		gap: 0.5em;
	}

	.internal-links a {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.8em;
		letter-spacing: 1px;
		text-transform: uppercase;
		padding: 6px 14px;
		color: #6b6b8a;
		border: 1px solid transparent;
		text-decoration: none;
		transition: all 0.2s;
	}

	.internal-links a:hover,
	.internal-links a.active {
		color: #00ff9f;
		border-color: #00ff9f;
		background: rgba(0, 255, 159, 0.05);
	}

	.social-links a {
		color: #6b6b8a;
		display: flex;
		align-items: center;
		border-bottom: none;
		transition: color 0.2s;
	}

	.social-links a:hover {
		color: #00ff9f;
		border-bottom: none;
	}

	@media (max-width: 720px) {
		.social-links { display: none; }
		.internal-links a { padding: 6px 10px; }
	}
</style>