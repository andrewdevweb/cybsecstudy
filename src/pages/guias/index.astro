---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title="Guías Interactivas — CybSecStudy" description="Guías visuales e interactivas de ciberseguridad y redes." />
</head>
<body>
  <Header />
  <main>
    <div style="padding:40px 0 32px;border-bottom:1px solid #1e1e2e;margin-bottom:40px">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:3px;color:#00ff9f;margin-bottom:16px">// Guías Interactivas</div>
      <h1>Guías</h1>
      <p style="color:#6b6b8a;font-size:15px;max-width:520px">Aprende con guías visuales e interactivas. Cada guía incluye explicaciones, diagramas y quiz.</p>
    </div>
    <a href="/guias/modelo-osi" style="display:flex;gap:20px;align-items:center;background:#12121a;border:1px solid #1e1e2e;padding:24px;text-decoration:none;margin-bottom:10px;transition:border-color 0.2s">
      <div style="font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:700;color:#00ff9f;width:40px">01</div>
      <div>
        <div style="font-size:17px;font-weight:800;color:#e8eaf0;margin-bottom:4px">Modelo OSI</div>
        <div style="font-size:13px;color:#6b6b8a">Las 7 capas explicadas con protocolos y quiz interactivo.</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#00ff9f;border:1px solid #00ff9f;padding:2px 8px;display:inline-block;margin-top:8px">Redes</div>
      </div>
    </a>
    <a href="/guias/packets-frames" style="display:flex;gap:20px;align-items:center;background:#12121a;border:1px solid #1e1e2e;padding:24px;text-decoration:none;margin-bottom:10px;transition:border-color 0.2s">
      <div style="font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:700;color:#4d96ff;width:40px">02</div>
      <div>
        <div style="font-size:17px;font-weight:800;color:#e8eaf0;margin-bottom:4px">Packets & Frames</div>
        <div style="font-size:13px;color:#6b6b8a">TCP, UDP, Three-Way Handshake y puertos principales.</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#4d96ff;border:1px solid #4d96ff;padding:2px 8px;display:inline-block;margin-top:8px">Redes</div>
      </div>
    </a>
    <a href="/guias/ampliando-tu-red" style="display:flex;gap:20px;align-items:center;background:#12121a;border:1px solid #1e1e2e;padding:24px;text-decoration:none;margin-bottom:10px;transition:border-color 0.2s">
      <div style="font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:700;color:#ff9f43;width:40px">03</div>
      <div>
        <div style="font-size:17px;font-weight:800;color:#e8eaf0;margin-bottom:4px">Ampliando tu Red</div>
        <div style="font-size:13px;color:#6b6b8a">Port Forwarding, Firewalls, VPNs, Routers y Switches.</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#ff9f43;border:1px solid #ff9f43;padding:2px 8px;display:inline-block;margin-top:8px">Redes</div>
      </div>
    </a>
    <a href="/guias/dns" style="display:flex;gap:20px;...">
      <div style="font-family:'JetBrains Mono',...;color:#00ff9f;width:40px">04</div>
      <div>
        <div style="font-size:17px;font-weight:800;color:#e8eaf0;margin-bottom:4px">DNS</div>
        <div style="font-size:13px;color:#6b6b8a">Sistema de Nombres de Dominio — jerarquía, registros y resolución</div>
        <div style="...;color:#00ff9f;border:1px solid #00ff9f;...">REDES</div>
      </div>
    </a>
  </main>
  <Footer />
</body>
</html>