<script>
// @ts-nocheck

// ── CATEGORY CARDS ──
document.querySelectorAll('.cat-card').forEach(card => {
  card.addEventListener('click', () => {
    const cat = card.dataset.cat;
    const panel = document.getElementById('panel-' + cat);
    const isOpen = card.classList.contains('active');

    // close all
    document.querySelectorAll('.cat-card').forEach(c => c.classList.remove('active'));
    document.querySelectorAll('.cat-panel').forEach(p => p.classList.remove('open'));

    if (!isOpen) {
      card.classList.add('active');
      panel.classList.add('open');
      // smooth scroll to panel
      setTimeout(() => panel.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
    }
  });
});

// ── CLOSE BUTTONS ──
document.querySelectorAll('.panel-close').forEach(btn => {
  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    const cat = btn.dataset.close;
    document.getElementById('panel-' + cat).classList.remove('open');
    document.querySelector('[data-cat="' + cat + '"]').classList.remove('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
});

// ── SEARCH ──
const allGuides = [
  { num:'01', href:'/guias/computer',         title:'Sistema Informático',           cat:'Fundamentos', color:'#6bcb77', desc:'CPU, RAM, GPU y secuencia de arranque.' },
  { num:'02', href:'/guias/comptypes',         title:'Tipos de Computadoras',         cat:'Fundamentos', color:'#6bcb77', desc:'Portátiles, servidores, IoT y smartphones.' },
  { num:'03', href:'/guias/virt',              title:'Virtualización',                cat:'Fundamentos', color:'#6bcb77', desc:'Hipervisores, VMs y contenedores.' },
  { num:'04', href:'/guias/cloud',             title:'Cloud Computing',               cat:'Fundamentos', color:'#6bcb77', desc:'IaaS, PaaS, SaaS y seguridad cloud.' },
  { num:'01', href:'/guias/triada-cid',        title:'Tríada CID',                    cat:'Seguridad',   color:'#ff6b6b', desc:'Confidencialidad, Integridad y Disponibilidad aplicadas.' },
  { num:'02', href:'/guias/aaa-control-acceso',title:'AAA y Control de Acceso',       cat:'Seguridad',   color:'#ff6b6b', desc:'Autenticacion, autorizacion, accounting y trazabilidad.' },
  { num:'03', href:'/guias/riesgo-amenazas-vulnerabilidades',title:'Riesgo, Amenazas y Vulnerabilidades', cat:'Seguridad', color:'#ff6b6b', desc:'Activos, amenazas, vulnerabilidades, impacto y probabilidad.' },
  { num:'01', href:'/guias/os-intro',          title:'Sistemas Operativos',           cat:'Windows',     color:'#00bfff', desc:'Kernel, User Space, GUI vs CLI y familias de SO.' },
  { num:'02', href:'/guias/windows-basics',    title:'Windows Básico',                cat:'Windows',     color:'#00bfff', desc:'Autenticación, registro y seguridad nativa.' },
  { num:'03', href:'/guias/windows-cmd-intro', title:'CLI de Windows — Introducción', cat:'Windows',     color:'#00bfff', desc:'CMD, PowerShell, Windows Terminal y primeros comandos.' },
  { num:'04', href:'/guias/windows-nav',       title:'Navegación y Sistema de Archivos', cat:'Windows',  color:'#00bfff', desc:'cd, dir, dir /a, rutas absolutas y relativas, y tree.' },
  { num:'05', href:'/guias/windows-files',     title:'Gestión de Archivos', cat:'Windows', color:'#00bfff', desc:'copy, move, del, mkdir, rmdir, ren y type en CMD.' },
  { num:'01', href:'/guias/linux-cli-intro',   title:'Introducción a Linux y la CLI', cat:'Linux & CLI', color:'#ff9f43', desc:'Filosofía Unix, CLI vs GUI, terminal.' },
  { num:'02', href:'/guias/linux-shell',       title:'Terminal, Consola y Shell',     cat:'Linux & CLI', color:'#ff9f43', desc:'Bash, zsh, $PATH y .bashrc.' },
  { num:'03', href:'/guias/linux-fs',          title:'Sistema de Archivos Linux',     cat:'Linux & CLI', color:'#ff9f43', desc:'FHS, /etc, /home, /var, rutas e inodes.' },
  { num:'04', href:'/guias/linux-nav',         title:'Navegación Básica',             cat:'Linux & CLI', color:'#ff9f43', desc:'ls, cd, pwd, find, wildcards y atajos.' },
  { num:'05', href:'/guias/linux-files',       title:'Gestión de Archivos',           cat:'Linux & CLI', color:'#ff9f43', desc:'cp, mv, rm, touch y mkdir.' },
  { num:'06', href:'/guias/linux-view',        title:'Ver Contenido de Archivos',     cat:'Linux & CLI', color:'#ff9f43', desc:'cat, less, head, tail y grep.' },
  { num:'07', href:'/guias/linux-perms',       title:'Permisos en Linux',             cat:'Linux & CLI', color:'#ff9f43', desc:'rwx, chmod, chown, SUID y sticky bit.' },
  { num:'01', href:'/guias/modelo-osi',        title:'Modelo OSI',                    cat:'Redes',       color:'#4d96ff', desc:'Las 7 capas con protocolos y quiz.' },
  { num:'02', href:'/guias/packets-frames',    title:'Packets & Frames',              cat:'Redes',       color:'#4d96ff', desc:'TCP, UDP, Three-Way Handshake y puertos.' },
  { num:'03', href:'/guias/dns',               title:'DNS',                           cat:'Redes',       color:'#4d96ff', desc:'Jerarquía de dominios, registros y resolución.' },
  { num:'04', href:'/guias/ampliando-tu-red',  title:'Ampliando tu Red',              cat:'Redes',       color:'#4d96ff', desc:'Port Forwarding, Firewalls, VPNs, Routers.' },
  { num:'01', href:'/guias/clientserver',      title:'Modelo Cliente-Servidor',       cat:'Web',         color:'#ff6b9d', desc:'Cliente, servidor, DNS, puertos y HTTP.' },
  { num:'02', href:'/guias/http',              title:'HTTP en Detalle',               cat:'Web',         color:'#ff6b9d', desc:'Solicitudes, respuestas, métodos y cookies.' },
  { num:'03', href:'/guias/web',               title:'Cómo Funcionan los Sitios Web', cat:'Web',         color:'#ff6b9d', desc:'HTML, CSS, JavaScript y HTML Injection.' },
  { num:'04', href:'/guias/infra',             title:'La Web por Dentro',             cat:'Web',         color:'#ff6b9d', desc:'Balanceadores, CDN, WAF y servidores.' },
];

const searchInput = document.getElementById('searchInput');
const searchPanel = document.getElementById('searchPanel');
const catGrid = document.getElementById('catGrid');

searchInput.addEventListener('input', () => {
  const q = searchInput.value.trim().toLowerCase();

  if (q.length < 2) {
    searchPanel.classList.remove('open');
    searchPanel.innerHTML = '';
    catGrid.style.display = '';
    document.querySelectorAll('.cat-panel.open').forEach(p => p.style.display = '');
    return;
  }

  // hide cat cards while searching
  catGrid.style.display = 'none';
  document.querySelectorAll('.cat-panel').forEach(p => p.style.display = 'none');

  const matches = allGuides.filter(g =>
    g.title.toLowerCase().includes(q) ||
    g.desc.toLowerCase().includes(q) ||
    g.cat.toLowerCase().includes(q)
  );

  if (matches.length === 0) {
    searchPanel.innerHTML = '<div class="search-empty">// sin resultados para "' + q + '"</div>';
  } else {
    searchPanel.innerHTML =
      '<div style="font-family:JetBrains Mono,monospace;font-size:9px;letter-spacing:3px;color:#3a3a5a;margin-bottom:16px;text-transform:uppercase">// ' + matches.length + ' resultado' + (matches.length !== 1 ? 's' : '') + '</div>' +
      '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:10px">' +
      matches.map(g => `
        <a href="${g.href}" style="
          display:flex;align-items:center;gap:0;text-decoration:none;
          border:1px solid #1e1e2e;background:#0d0d18;overflow:hidden;
          transition:all 0.15s;
        " onmouseover="this.style.borderColor='${g.color}';this.style.background='#12121a'" onmouseout="this.style.borderColor='#1e1e2e';this.style.background='#0d0d18'">
          <div style="width:44px;height:64px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;color:${g.color};flex-shrink:0;border-right:1px solid #1e1e2e;">${g.num}</div>
          <div style="padding:12px 14px;flex:1;min-width:0;">
            <div style="font-size:13px;font-weight:700;color:#e8eaf0;margin-bottom:3px;">${g.title}</div>
            <div style="font-size:11px;color:#6b6b8a;">${g.desc}</div>
          </div>
          <div style="padding:0 12px;font-family:'JetBrains Mono',monospace;font-size:9px;color:${g.color};flex-shrink:0;letter-spacing:1px;">${g.cat}</div>
        </a>
      `).join('') +
      '</div>';
  }

  searchPanel.classList.add('open');
});

// restore on clear
searchInput.addEventListener('input', () => {
  if (searchInput.value.trim().length < 2) {
    catGrid.style.display = '';
    document.querySelectorAll('.cat-panel').forEach(p => p.style.display = '');
  }
});
</script>
