---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title="Guías Interactivas — CybSecStudy" description="Guías visuales e interactivas de ciberseguridad, organizadas por temática y nivel." />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    .page-header { padding: 40px 0 32px; border-bottom: 1px solid #1e1e2e; margin-bottom: 48px; }
    .page-tag { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 3px; color: #00ff9f; margin-bottom: 16px; }
    h1 { font-size: clamp(32px, 5vw, 52px) !important; letter-spacing: -2px !important; margin-bottom: 12px !important; }
    .page-desc { color: #6b6b8a; font-size: 15px; max-width: 520px; }

    /* ── CATEGORY GRID ── */
    .cat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; margin-bottom: 64px; }

    .cat-card {
      background: #12121a;
      border: 1px solid #1e1e2e;
      cursor: pointer;
      transition: all 0.2s;
      overflow: hidden;
      position: relative;
    }
    .cat-card:hover { border-color: var(--cc); transform: translateY(-3px); }
    .cat-card.active { border-color: var(--cc); }

    .cat-card-top { padding: 28px 28px 20px; border-bottom: 1px solid #1e1e2e; }
    .cat-icon { font-size: 28px; margin-bottom: 14px; display: block; }
    .cat-name { font-size: 22px; font-weight: 800; color: #e8eaf0; margin-bottom: 6px; }
    .cat-sub { font-size: 12px; color: #6b6b8a; line-height: 1.5; }

    .cat-card-bottom { padding: 14px 28px; display: flex; align-items: center; justify-content: space-between; }
    .cat-count { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--cc); }
    .cat-levels { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #3a3a5a; }
    .cat-arrow { font-size: 14px; color: var(--cc); transition: transform 0.2s; }
    .cat-card.active .cat-arrow { transform: rotate(90deg); }

    .cat-bar { height: 3px; background: var(--cc); opacity: 0; transition: opacity 0.2s; }
    .cat-card.active .cat-bar, .cat-card:hover .cat-bar { opacity: 1; }

    /* ── PANEL ── */
    .cat-panel { display: none; margin-bottom: 48px; }
    .cat-panel.open { display: block; }

    .panel-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #1e1e2e; }
    .panel-title { font-size: 18px; font-weight: 800; color: var(--pc); }
    .panel-desc { font-size: 13px; color: #6b6b8a; flex: 1; }
    .panel-close {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      padding: 6px 14px;
      border: 1px solid #1e1e2e;
      background: transparent;
      color: #6b6b8a;
      cursor: pointer;
      transition: all 0.2s;
      letter-spacing: 1px;
    }
    .panel-close:hover { border-color: var(--pc); color: var(--pc); }

    /* ── LEVELS ── */
    .level-block { margin-bottom: 24px; }
    .level-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px;
      letter-spacing: 3px;
      color: #3a3a5a;
      text-transform: uppercase;
      margin-bottom: 10px;
      padding-left: 2px;
    }
    .guides-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 10px; }

    .guide-card {
      background: #0d0d18;
      border: 1px solid #1e1e2e;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0;
      overflow: hidden;
      transition: all 0.15s;
    }
    .guide-card:hover { border-color: var(--pc); background: #12121a; }
    .guide-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      font-weight: 700;
      width: 44px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--pc);
      flex-shrink: 0;
      border-right: 1px solid #1e1e2e;
      opacity: 0.5;
      transition: opacity 0.15s;
    }
    .guide-card:hover .guide-num { opacity: 1; }
    .guide-info { padding: 12px 14px; min-width: 0; flex: 1; }
    .guide-title { font-size: 13px; font-weight: 700; color: #e8eaf0; line-height: 1.3; margin-bottom: 3px; }
    .guide-desc { font-size: 11px; color: #6b6b8a; line-height: 1.4; }
    .guide-go { padding: 0 14px; color: #2a2a3a; font-size: 12px; flex-shrink: 0; transition: color 0.15s; }
    .guide-card:hover .guide-go { color: var(--pc); }

    /* ── SEARCH ── */
    .search-wrap { position: relative; margin-bottom: 40px; }
    .search-input {
      width: 100%;
      background: #12121a;
      border: 1px solid #1e1e2e;
      color: #e8eaf0;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      padding: 12px 16px 12px 40px;
      outline: none;
      transition: border-color 0.2s;
      box-sizing: border-box;
    }
    .search-input:focus { border-color: #00ff9f; }
    .search-input::placeholder { color: #2a2a3a; }
    .search-ico { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #3a3a5a; font-family: 'JetBrains Mono', monospace; font-size: 11px; pointer-events: none; }
    .search-panel { display: none; }
    .search-panel.open { display: block; margin-bottom: 40px; }
    .search-empty { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #3a3a5a; padding: 16px 0; }

    @media (max-width: 600px) {
      .cat-grid { grid-template-columns: 1fr; }
      .guides-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <Header />
  <main>

    <div class="page-header">
      <div class="page-tag">// Guías Interactivas</div>
      <h1>Guías</h1>
      <p class="page-desc">Visuales, interactivas y con quiz. Elige una temática para ver las guías disponibles.</p>
    </div>

    <!-- SEARCH -->
    <div class="search-wrap">
      <span class="search-ico">//</span>
      <input class="search-input" type="text" id="searchInput" placeholder="Buscar entre todas las guías..." autocomplete="off"/>
    </div>
    <div class="search-panel" id="searchPanel"></div>

    <!-- CATEGORY CARDS -->
    <div class="cat-grid" id="catGrid">

      <div class="cat-card" style="--cc:#6bcb77" data-cat="fundamentos">
        <div class="cat-bar"></div>
        <div class="cat-card-top">
          <span class="cat-icon">🖥</span>
          <div class="cat-name">Fundamentos</div>
          <div class="cat-sub">Hardware, tipos de sistemas, virtualización y cloud computing.</div>
        </div>
        <div class="cat-card-bottom">
          <span class="cat-count">4 guías</span>
          <span class="cat-levels">2 niveles</span>
          <span class="cat-arrow">→</span>
        </div>
      </div>

      <div class="cat-card" style="--cc:#ff6b6b" data-cat="seguridad">
        <div class="cat-bar"></div>
        <div class="cat-card-top">
          <span class="cat-icon">🛡</span>
          <div class="cat-name">Seguridad</div>
          <div class="cat-sub">Conceptos base de ciberseguridad, modelos de defensa y analisis del riesgo.</div>
        </div>
        <div class="cat-card-bottom">
          <span class="cat-count">3 guías</span>
          <span class="cat-levels">1 nivel</span>
          <span class="cat-arrow">→</span>
        </div>
      </div>

      <div class="cat-card" style="--cc:#00bfff" data-cat="windows">
        <div class="cat-bar"></div>
        <div class="cat-card-top">
          <span class="cat-icon">⊞</span>
          <div class="cat-name">Windows</div>
          <div class="cat-sub">Sistema operativo, CLI, CMD, PowerShell y administración.</div>
        </div>
        <div class="cat-card-bottom">
          <span class="cat-count">5 guías</span>
          <span class="cat-levels">2 niveles</span>
          <span class="cat-arrow">→</span>
        </div>
      </div>

      <div class="cat-card" style="--cc:#ff9f43" data-cat="linux">
        <div class="cat-bar"></div>
        <div class="cat-card-top">
          <span class="cat-icon">🐧</span>
          <div class="cat-name">Linux & CLI</div>
          <div class="cat-sub">Terminal, shell, sistema de archivos y comandos esenciales.</div>
        </div>
        <div class="cat-card-bottom">
          <span class="cat-count">7 guías</span>
          <span class="cat-levels">2 niveles</span>
          <span class="cat-arrow">→</span>
        </div>
      </div>

      <div class="cat-card" style="--cc:#4d96ff" data-cat="redes">
        <div class="cat-bar"></div>
        <div class="cat-card-top">
          <span class="cat-icon">🌐</span>
          <div class="cat-name">Redes</div>
          <div class="cat-sub">Modelo OSI, TCP/IP, DNS, firewalls, VPNs y protocolos de red.</div>
        </div>
        <div class="cat-card-bottom">
          <span class="cat-count">4 guías</span>
          <span class="cat-levels">2 niveles</span>
          <span class="cat-arrow">→</span>
        </div>
      </div>

      <div class="cat-card" style="--cc:#ff6b9d" data-cat="web">
        <div class="cat-bar"></div>
        <div class="cat-card-top">
          <span class="cat-icon">🕸</span>
          <div class="cat-name">Web</div>
          <div class="cat-sub">HTTP, HTML, JavaScript, infraestructura y cliente-servidor.</div>
        </div>
        <div class="cat-card-bottom">
          <span class="cat-count">4 guías</span>
          <span class="cat-levels">2 niveles</span>
          <span class="cat-arrow">→</span>
        </div>
      </div>

    </div>

    <!-- PANELS (hidden by default) -->
    <div class="cat-panel" id="panel-fundamentos" style="--pc:#6bcb77">
      <div class="panel-header">
        <div class="panel-title">Fundamentos</div>
        <div class="panel-desc">La base de todo — hardware, tipos de sistemas, virtualización y cloud.</div>
        <button class="panel-close" data-close="fundamentos">✕ Cerrar</button>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel 1 — Hardware y Tipos de Sistemas</div>
        <div class="guides-grid">
          <a href="/guias/computer" class="guide-card" style="--pc:#6bcb77">
            <div class="guide-num">01</div>
            <div class="guide-info">
              <div class="guide-title">Sistema Informático</div>
              <div class="guide-desc">CPU, RAM, almacenamiento, GPU y secuencia de arranque.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/comptypes" class="guide-card" style="--pc:#6bcb77">
            <div class="guide-num">02</div>
            <div class="guide-info">
              <div class="guide-title">Tipos de Computadoras</div>
              <div class="guide-desc">Portátiles, servidores, IoT, embebidos y smartphones.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
        </div>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel 2 — Virtualización y Cloud</div>
        <div class="guides-grid">
          <a href="/guias/virt" class="guide-card" style="--pc:#6bcb77">
            <div class="guide-num">03</div>
            <div class="guide-info">
              <div class="guide-title">Virtualización</div>
              <div class="guide-desc">Hipervisores Tipo 1 y 2, VMs y contenedores Docker.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/cloud" class="guide-card" style="--pc:#6bcb77">
            <div class="guide-num">04</div>
            <div class="guide-info">
              <div class="guide-title">Cloud Computing</div>
              <div class="guide-desc">IaaS, PaaS, SaaS, proveedores y seguridad en la nube.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
        </div>
      </div>
    </div>

    <div class="cat-panel" id="panel-seguridad" style="--pc:#ff6b6b">
      <div class="panel-header">
        <div class="panel-title">Seguridad</div>
        <div class="panel-desc">Modelos mentales y fundamentos que te ayudan a pensar la seguridad con criterio.</div>
        <button class="panel-close" data-close="seguridad">✕ Cerrar</button>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel 1 — Fundamentos de Seguridad</div>
        <div class="guides-grid">
          <a href="/guias/triada-cid" class="guide-card" style="--pc:#ff6b6b">
            <div class="guide-num">01</div>
            <div class="guide-info">
              <div class="guide-title">Tríada CID</div>
              <div class="guide-desc">Confidencialidad, Integridad y Disponibilidad con ejemplos y quiz.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/aaa-control-acceso" class="guide-card" style="--pc:#ff6b6b">
            <div class="guide-num">02</div>
            <div class="guide-info">
              <div class="guide-title">AAA y Control de Acceso</div>
              <div class="guide-desc">Autenticacion, autorizacion, accounting, sesiones y trazabilidad.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/riesgo-amenazas-vulnerabilidades" class="guide-card" style="--pc:#ff6b6b">
            <div class="guide-num">03</div>
            <div class="guide-info">
              <div class="guide-title">Riesgo, Amenazas y Vulnerabilidades</div>
              <div class="guide-desc">Activos, impacto, probabilidad y priorizacion del riesgo.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
        </div>
      </div>
    </div>

    <div class="cat-panel" id="panel-windows" style="--pc:#00bfff">
      <div class="panel-header">
        <div class="panel-title">Windows</div>
        <div class="panel-desc">Desde el SO hasta la terminal — todo lo que necesitas para dominar Windows.</div>
        <button class="panel-close" data-close="windows">✕ Cerrar</button>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel 1 — Sistema Operativo</div>
        <div class="guides-grid">
          <a href="/guias/os-intro" class="guide-card" style="--pc:#00bfff">
            <div class="guide-num">01</div>
            <div class="guide-info">
              <div class="guide-title">Sistemas Operativos</div>
              <div class="guide-desc">Kernel, User Space, GUI vs CLI y familias de SO.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/windows-basics" class="guide-card" style="--pc:#00bfff">
            <div class="guide-num">02</div>
            <div class="guide-info">
              <div class="guide-title">Windows Básico</div>
              <div class="guide-desc">Autenticación, registro, Task Manager y seguridad nativa.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
        </div>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel 2 — CLI de Windows</div>
        <div class="guides-grid">
          <a href="/guias/windows-cmd-intro" class="guide-card" style="--pc:#00bfff">
            <div class="guide-num">03</div>
            <div class="guide-info">
              <div class="guide-title">CLI de Windows — Introducción</div>
              <div class="guide-desc">CMD, PowerShell, Windows Terminal y primeros comandos.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/windows-nav" class="guide-card" style="--pc:#00bfff">
            <div class="guide-num">04</div>
            <div class="guide-info">
              <div class="guide-title">Navegación y Sistema de Archivos</div>
              <div class="guide-desc">cd, dir, dir /a, rutas absolutas y relativas, y tree.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/windows-files" class="guide-card" style="--pc:#00bfff">
            <div class="guide-num">05</div>
            <div class="guide-info">
              <div class="guide-title">Gestión de Archivos</div>
              <div class="guide-desc">copy, move, del, mkdir, rmdir, ren y type en CMD.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
        </div>
      </div>
    </div>

    <div class="cat-panel" id="panel-linux" style="--pc:#ff9f43">
      <div class="panel-header">
        <div class="panel-title">Linux & CLI</div>
        <div class="panel-desc">Domina la terminal — el campo de batalla de la ciberseguridad.</div>
        <button class="panel-close" data-close="linux">✕ Cerrar</button>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel Básico — Fundamentos de la terminal</div>
        <div class="guides-grid">
          <a href="/guias/linux-cli-intro" class="guide-card" style="--pc:#ff9f43">
            <div class="guide-num">01</div>
            <div class="guide-info">
              <div class="guide-title">Introducción a Linux y la CLI</div>
              <div class="guide-desc">Qué es Linux, filosofía Unix, CLI vs GUI.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/linux-shell" class="guide-card" style="--pc:#ff9f43">
            <div class="guide-num">02</div>
            <div class="guide-info">
              <div class="guide-title">Terminal, Consola y Shell</div>
              <div class="guide-desc">Bash, zsh, $PATH, .bashrc y tipos de shell.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/linux-fs" class="guide-card" style="--pc:#ff9f43">
            <div class="guide-num">03</div>
            <div class="guide-info">
              <div class="guide-title">Sistema de Archivos Linux</div>
              <div class="guide-desc">FHS, /etc, /home, /var, /proc, rutas e inodes.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/linux-nav" class="guide-card" style="--pc:#ff9f43">
            <div class="guide-num">04</div>
            <div class="guide-info">
              <div class="guide-title">Navegación Básica</div>
              <div class="guide-desc">ls, cd, pwd, find, wildcards y atajos de teclado.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/linux-files" class="guide-card" style="--pc:#ff9f43">
            <div class="guide-num">05</div>
            <div class="guide-info">
              <div class="guide-title">Gestión de Archivos</div>
              <div class="guide-desc">cp, mv, rm, touch y mkdir. Copiar, mover, borrar y crear.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/linux-view" class="guide-card" style="--pc:#ff9f43">
            <div class="guide-num">06</div>
            <div class="guide-info">
              <div class="guide-title">Ver Contenido de Archivos</div>
              <div class="guide-desc">cat, less, head, tail y grep. Leer, paginar y filtrar.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
        </div>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel Intermedio — Comprensión operativa</div>
        <div class="guides-grid">
          <a href="/guias/linux-perms" class="guide-card" style="--pc:#ff9f43">
            <div class="guide-num">07</div>
            <div class="guide-info">
              <div class="guide-title">Permisos en Linux</div>
              <div class="guide-desc">rwx, chmod, chown, SUID y sticky bit en profundidad.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
        </div>
      </div>
    </div>

    <div class="cat-panel" id="panel-redes" style="--pc:#4d96ff">
      <div class="panel-header">
        <div class="panel-title">Redes</div>
        <div class="panel-desc">Protocolos, capas, DNS, firewalls y VPNs.</div>
        <button class="panel-close" data-close="redes">✕ Cerrar</button>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel 1 — Protocolos y Capas</div>
        <div class="guides-grid">
          <a href="/guias/modelo-osi" class="guide-card" style="--pc:#4d96ff">
            <div class="guide-num">01</div>
            <div class="guide-info">
              <div class="guide-title">Modelo OSI</div>
              <div class="guide-desc">Las 7 capas con protocolos y quiz interactivo.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/packets-frames" class="guide-card" style="--pc:#4d96ff">
            <div class="guide-num">02</div>
            <div class="guide-info">
              <div class="guide-title">Packets & Frames</div>
              <div class="guide-desc">TCP, UDP, Three-Way Handshake y puertos principales.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
          <a href="/guias/dns" class="guide-card" style="--pc:#4d96ff">
            <div class="guide-num">03</div>
            <div class="guide-info">
              <div class="guide-title">DNS</div>
              <div class="guide-desc">Jerarquía de dominios, registros y resolución paso a paso.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
        </div>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel 2 — Infraestructura de Red</div>
        <div class="guides-grid">
          <a href="/guias/ampliando-tu-red" class="guide-card" style="--pc:#4d96ff">
            <div class="guide-num">04</div>
            <div class="guide-info">
              <div class="guide-title">Ampliando tu Red</div>
              <div class="guide-desc">Port Forwarding, Firewalls, VPNs, Routers y Switches.</div>
            </div>
            <div class="guide-go">→</div>
          </a>
        </div>
      </div>
    </div>

    <div class="cat-panel" id="panel-web" style="--pc:#ff6b9d">
      <div class="panel-header">
        <div class="panel-title">Web</div>
        <div class="panel-desc">HTTP, HTML, JavaScript, infraestructura y cliente-servidor.</div>
        <button class="panel-close" data-close="web">✕ Cerrar</button>
      </div>

      <div class="level-block">
        <div class="level-label">// Nivel 1 — Fundamentos Web</div>
        <div class="guides-grid">
          <a href="/guias/clientserver" class="guide-card" style="--pc:#ff6b9d">
            <div class="guide-num">01</div>
            <div class="guide-info">
              <div class="guide-title">Modelo Cliente-Servidor</div>
