---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title="Cómo Funcionan los Sitios Web — CybSecStudy" description="Guía interactiva sobre HTML, CSS, JavaScript, exposición de datos y HTML injection." />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    .guide-header { padding: 40px 0 32px; border-bottom: 1px solid #1e1e2e; margin-bottom: 32px; }
    .guide-tag { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 3px; color: #00ff9f; margin-bottom: 16px; }
    h1 { font-size: clamp(32px, 5vw, 56px) !important; letter-spacing: -2px !important; margin-bottom: 16px !important; }
    .accent { color: #00ff9f; }
    .guide-desc { color: #6b6b8a; font-size: 15px; max-width: 560px; line-height: 1.7; }
    .intro-card { background: #12121a; border: 1px solid #1e1e2e; border-left: 3px solid #00ff9f; padding: 20px 24px; margin-bottom: 40px; }
    .intro-card p { color: #b0b0c8; line-height: 1.8; font-size: 15px; margin: 0 0 8px; }
    .intro-card p:last-child { margin: 0; }
    .intro-card strong { color: #00ff9f; }
    .section-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 3px; color: #6b6b8a; text-transform: uppercase; margin-bottom: 16px; }
    .concepts-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 48px; }
    .concept { background: #12121a; border: 1px solid #1e1e2e; cursor: pointer; transition: all 0.2s; overflow: hidden; }
    .concept:hover { border-color: var(--cc); transform: translateX(4px); }
    .concept.active { border-color: var(--cc) !important; }
    .concept-header { display: flex; align-items: center; gap: 0; }
    .concept-num { width: 48px; height: 52px; display: flex; align-items: center; justify-content: center; background: var(--cc); font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 13px; color: #000; flex-shrink: 0; }
    .concept-title { padding: 0 20px; font-weight: 800; font-size: 15px; color: var(--cc); }
    .concept-badge { margin-left: auto; margin-right: 16px; font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 4px 12px; border: 1px solid var(--cc); color: var(--cc); opacity: 0.6; white-space: nowrap; }
    .concept-body { display: none !important; padding: 20px 20px 20px 68px; border-top: 1px solid #1e1e2e; }
    .concept.active .concept-body { display: block !important; }
    .concept-body p { font-size: 13px !important; color: #b0b0c8 !important; line-height: 1.8 !important; margin-bottom: 10px; }
    .concept-body p:last-child { margin-bottom: 0; }
    .concept-body code { font-family: 'JetBrains Mono', monospace; font-size: 11px; padding: 2px 7px; background: rgba(255,255,255,0.04); border: 1px solid #1e1e2e; color: var(--cc); }
    .concept-body ul { padding: 0; list-style: none; display: flex; flex-direction: column; gap: 4px; margin-bottom: 10px; }
    .concept-body li { font-size: 13px !important; color: #b0b0c8 !important; line-height: 1.7 !important; }
    .concept-body li::before { content: '▸ '; color: var(--cc); }
    .concept-body strong { color: #e8eaf0; font-weight: 700; }
    .code-block { background: #0a0a0f; border: 1px solid #1e1e2e; border-left: 2px solid var(--cc, #00ff9f); padding: 12px 16px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #b0b0c8; line-height: 1.9; margin-top: 10px; white-space: pre; overflow-x: auto; }
    .progress-bar { height: 2px; background: #1e1e2e; margin-bottom: 24px; }
    .progress-fill { height: 100%; background: #00ff9f; transition: width 0.4s ease; }
    .quiz-card { background: #12121a; border: 1px solid #1e1e2e; padding: 28px; margin-bottom: 20px; }
    .quiz-question { font-size: 16px !important; font-weight: 600; margin-bottom: 20px; line-height: 1.5; color: #e8eaf0; }
    .quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
    .quiz-option { background: transparent; border: 1px solid #1e1e2e; color: #b0b0c8; padding: 12px 16px; cursor: pointer; font-family: 'Syne', sans-serif; font-size: 13px; text-align: left; transition: all 0.2s; }
    .quiz-option:hover { border-color: #00ff9f; color: #00ff9f; }
    .quiz-option.correct { border-color: #6bcb77 !important; background: rgba(107,203,119,0.08); color: #6bcb77 !important; }
    .quiz-option.wrong { border-color: #ff6b6b !important; background: rgba(255,107,107,0.08); color: #ff6b6b !important; }
    .quiz-feedback { display: none; font-size: 13px; padding: 10px 14px; border-left: 3px solid; margin-top: 10px; line-height: 1.6; }
    .quiz-feedback.show { display: block; }
    .quiz-feedback.correct { border-color: #6bcb77; color: #6bcb77; background: rgba(107,203,119,0.05); }
    .quiz-feedback.wrong { border-color: #ff6b6b; color: #b0b0c8; background: rgba(255,107,107,0.05); }
    .quiz-nav { display: flex; align-items: center; gap: 14px; margin-top: 8px; }
    .btn { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 1px; padding: 10px 20px; border: 1px solid #00ff9f; background: transparent; color: #00ff9f; cursor: pointer; transition: all 0.2s; text-transform: uppercase; }
    .btn:hover { background: #00ff9f; color: #000; }
    .btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .btn:disabled:hover { background: transparent; color: #00ff9f; }
    .score { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #6b6b8a; margin-left: auto; }
    @media (max-width: 640px) {
      .quiz-options { grid-template-columns: 1fr; }
      .concept-badge { display: none; }
    }
  </style>
</head>
<body>
  <Header />
  <main>

    <div class="guide-header">
      <div class="guide-tag">// Web — Guía Interactiva</div>
      <h1>Cómo Funcionan los <span class="accent">Sitios Web</span></h1>
      <p class="guide-desc">Frontend, Backend, HTML, CSS, JavaScript y las primeras vulnerabilidades web que todo profesional de seguridad debe conocer.</p>
    </div>

    <div class="intro-card">
      <p>Cuando visitas una web, tu navegador envía una <strong>solicitud</strong> a un servidor. El servidor procesa la petición y devuelve una <strong>respuesta</strong> con los datos para mostrar la página.</p>
      <p>Un sitio web tiene dos partes: el <strong>Front End</strong> (lo que renderiza tu navegador) y el <strong>Back End</strong> (el servidor que procesa y responde).</p>
    </div>

    <div class="section-label">// Flujo de solicitud</div>
    <img src="/web-flow.svg" alt="Flujo browser-internet-server" style="width:100%;margin-bottom:32px;border:none;border-radius:0" />

    <div class="section-label">// Los 3 pilares — clic para expandir</div>
    <div class="concepts-list">

      <div class="concept" style="--cc:#ff6b9d">
        <div class="concept-header">
          <div class="concept-num">HTML</div>
          <div class="concept-title">HyperText Markup Language</div>
          <div class="concept-badge">estructura y contenido</div>
        </div>
        <div class="concept-body">
          <p>HTML define la estructura de una página mediante <strong>elementos</strong> (etiquetas). Todo documento HTML sigue la misma base:</p>
          <div class="code-block">&lt;!DOCTYPE html&gt;
&lt;html&gt;
  &lt;head&gt;
    &lt;title&gt;Mi Página&lt;/title&gt;
  &lt;/head&gt;
  &lt;body&gt;
    &lt;h1&gt;Título principal&lt;/h1&gt;
    &lt;p id="demo" class="texto"&gt;Párrafo&lt;/p&gt;
    &lt;img src="img/cat.jpg" alt="Un gato"&gt;
  &lt;/body&gt;
&lt;/html&gt;</div>
          <p style="margin-top:12px">Atributos importantes:</p>
          <ul>
            <li><code>id</code> — <strong>único por elemento</strong> — usado por JS para identificarlo</li>
            <li><code>class</code> — <strong>compartido</strong> entre elementos — usado para estilos CSS</li>
            <li><code>src</code> — ruta de un recurso externo (imagen, script)</li>
          </ul>
          <p>Puedes ver el HTML de cualquier web con <code>Ctrl+U</code> o clic derecho → Ver código fuente.</p>
        </div>
      </div>

      <div class="concept" style="--cc:#4d96ff">
        <div class="concept-header">
          <div class="concept-num">CSS</div>
          <div class="concept-title">Cascading Style Sheets</div>
          <div class="concept-badge">estilo visual</div>
        </div>
        <div class="concept-body">
          <p>CSS controla cómo se ve el HTML: colores, fuentes, tamaños, layout, animaciones. Se aplica por <strong>selectores</strong> que apuntan a elementos HTML.</p>
          <div class="code-block">/* Por etiqueta */
h1 &#123; color: #00ff9f; font-size: 2em; &#125;

/* Por clase */
.bold-text &#123; font-weight: 700; &#125;

/* Por id */
#demo &#123; background: #12121a; padding: 10px; &#125;</div>
          <p style="margin-top:10px">Desde el punto de vista de seguridad, CSS también puede revelar información sobre la estructura del sitio si se examina el código fuente.</p>
        </div>
      </div>

      <div class="concept" style="--cc:#ffd93d">
        <div class="concept-header">
          <div class="concept-num">JS</div>
          <div class="concept-title">JavaScript</div>
          <div class="concept-badge">interactividad y lógica</div>
        </div>
        <div class="concept-body">
          <p>JavaScript hace las páginas <strong>interactivas</strong>. Sin él, todo sería estático. JS puede modificar el DOM, gestionar eventos y comunicarse con el servidor.</p>
          <div class="code-block">// Modificar el DOM
document.getElementById("demo").innerHTML = "Hack the Planet";

// Evento onclick
&lt;button onclick='document.getElementById("demo").innerHTML = "Clic!"'&gt;
  Haz clic
&lt;/button&gt;

// Script externo
&lt;script src="/js/app.js"&gt;&lt;/script&gt;</div>
          <p style="margin-top:10px">⚠️ El código JavaScript del lado del cliente es <strong>visible para cualquier usuario</strong> — nunca pongas secretos (API keys, contraseñas) en JS del frontend.</p>
        </div>
      </div>

    </div>

    <div class="section-label" style="margin-top:48px">// Vulnerabilidades web — clic para expandir</div>
    <div class="concepts-list">

      <div class="concept" style="--cc:#ff6b6b">
        <div class="concept-header">
          <div class="concept-num" style="font-size:9px">EXP</div>
          <div class="concept-title">Exposición de Datos Sensibles</div>
          <div class="concept-badge">código fuente del cliente</div>
        </div>
        <div class="concept-body">
          <p>Ocurre cuando un sitio web deja información confidencial visible en el código fuente — HTML, CSS o JavaScript accesible desde el navegador.</p>
          <p><strong>Qué buscar al auditar:</strong></p>
          <ul>
            <li>Comentarios HTML con credenciales o notas de desarrollo</li>
            <li>Contraseñas o tokens hardcodeados en JavaScript</li>
            <li>URLs ocultas a secciones privadas o paneles de admin</li>
            <li>Claves de API en el código del frontend</li>
          </ul>
          <div class="code-block">&lt;!-- TODO: eliminar antes de producción --&gt;
&lt;!-- admin:password123 --&gt;
&lt;a href="/secret-admin-panel"&gt;&lt;/a&gt;

// En JavaScript:
const API_KEY = "sk-abc123xyz";  // ⚠️ visible para todos</div>
          <p style="margin-top:10px">Usa <code>Ctrl+U</code> o las DevTools para revisar el código fuente de cualquier página que estés analizando.</p>
        </div>
      </div>

      <div class="concept" style="--cc:#ff9f43">
        <div class="concept-header">
          <div class="concept-num" style="font-size:9px">INJ</div>
          <div class="concept-title">HTML Injection</div>
          <div class="concept-badge">input sin sanitizar</div>
        </div>
        <div class="concept-body">
          <p>Ocurre cuando el input del usuario se inserta directamente en el HTML de la página <strong>sin sanitizar</strong>. El navegador renderiza ese input como código real.</p>
          <img src="/web-injection.svg" alt="HTML Injection diagram" style="width:100%;margin:12px 0;border:none;border-radius:0" />
          <div class="code-block">// VULNERABLE — innerHTML acepta HTML
getElementById("msg").innerHTML = "Hola " + userInput;

// Si el usuario escribe: &lt;h1&gt;Hackeado&lt;/h1&gt;
// El navegador lo renderiza como un H1 real

// SEGURO — textContent solo muestra texto plano
getElementById("msg").textContent = "Hola " + userInput;</div>
          <p style="margin-top:10px"><strong>Consecuencias:</strong></p>
          <ul>
            <li>Modificar visualmente la página para engañar a otros usuarios</li>
            <li>Phishing — mostrar formularios de login falsos</li>
            <li>Escalada a <strong>XSS</strong> (Cross-Site Scripting) si se inyecta JavaScript</li>
          </ul>
          <p>Regla de oro: <strong>nunca confíes en la entrada del usuario</strong>. Sanitiza siempre antes de usar el input en el DOM.</p>
        </div>
      </div>

    </div>

    <div class="section-label" style="margin-top:60px">// Quiz</div>
    <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
    <div class="quiz-card" id="quizCard">
      <div class="quiz-question" id="quizQuestion"></div>
      <div class="quiz-options" id="quizOptions"></div>
      <div class="quiz-feedback" id="quizFeedback"></div>
      <div class="quiz-nav">
        <button class="btn" id="nextBtn" disabled>Siguiente →</button>
        <span class="score" id="scoreLabel">0 / 0 correctas</span>
      </div>
    </div>

  </main>
  <Footer />
</body>
</html>

<script>
// @ts-nocheck
document.querySelectorAll('.concept').forEach(el => {
  el.addEventListener('click', () => {
    const was = el.classList.contains('active');
    document.querySelectorAll('.concept').forEach(x => x.classList.remove('active'));
    if (!was) el.classList.add('active');
  });
});

const questions = [
  { q: "¿Qué es el Front End de un sitio web?", opts: ["El servidor que procesa las solicitudes","La base de datos","La parte que renderiza el navegador del usuario","El firewall de la aplicación"], correct: 2, exp: "El Front End es el lado del cliente — lo que tu navegador renderiza y muestra al usuario." },
  { q: "¿Para qué sirve HTML?", opts: ["Para añadir interactividad","Para definir la estructura y contenido de la página","Para estilizar visualmente la página","Para gestionar el servidor"], correct: 1, exp: "HTML (HyperText Markup Language) define la estructura y el contenido de la página mediante etiquetas." },
  { q: "¿Cuál es la diferencia entre 'id' y 'class' en HTML?", opts: ["No hay diferencia","id es para imágenes, class para texto","id es único por elemento, class puede compartirse","class es más rápido que id"], correct: 2, exp: "id debe ser único por elemento. class puede aplicarse a múltiples elementos a la vez." },
  { q: "¿Qué tecnología añade interactividad a las páginas web?", opts: ["HTML","CSS","SQL","JavaScript"], correct: 3, exp: "JavaScript permite actualizar la página dinámicamente, gestionar eventos y manipular el DOM." },
  { q: "¿Cuál de estas es una fuente de exposición de datos sensibles?", opts: ["El servidor DNS","Credenciales hardcodeadas en comentarios HTML","El protocolo TCP","El certificado SSL"], correct: 1, exp: "Los comentarios HTML con credenciales, tokens en JavaScript y rutas ocultas son ejemplos típicos de exposición de datos en el código fuente." },
  { q: "¿Qué es HTML Injection?", opts: ["Un ataque al servidor web","Código HTML inyectado por el usuario en páginas sin sanitizar","Un error de CSS","Una vulnerabilidad del protocolo HTTP"], correct: 1, exp: "HTML Injection ocurre cuando el input del usuario se inserta en el DOM sin sanitizar, permitiendo inyectar etiquetas HTML reales." },
  { q: "¿Cuál es la forma segura de mostrar input del usuario en el DOM?", opts: ["innerHTML","outerHTML","textContent","document.write"], correct: 2, exp: "textContent trata el input como texto plano, sin interpretar HTML. innerHTML es vulnerable a injection." },
  { q: "¿Por qué no deberías poner claves de API en JavaScript del frontend?", opts: ["Porque JavaScript no soporta strings","Porque hace la página más lenta","Porque cualquier usuario puede ver el código fuente","Porque el servidor no lo acepta"], correct: 2, exp: "El JavaScript del lado del cliente es visible para cualquier usuario con Ctrl+U o las DevTools — nunca pongas secretos ahí." },
  { q: "¿A qué vulnerabilidad puede escalar una HTML Injection si se inyecta JavaScript?", opts: ["SQL Injection","Buffer Overflow","XSS (Cross-Site Scripting)","CSRF"], correct: 2, exp: "Si el sitio permite inyectar JavaScript además de HTML, HTML Injection escala a XSS — Cross-Site Scripting." },
  { q: "¿Cuál es la regla de oro de seguridad web respecto al input del usuario?", opts: ["Confiar siempre en el usuario","Nunca confiar en el input del usuario — siempre sanitizar","Usar solo GET, nunca POST","Deshabilitar JavaScript"], correct: 1, exp: "Nunca confíes en la entrada del usuario. Toda información del cliente debe ser sanitizada antes de usarse." }
];

let current = 0, score = 0, answered = false;

function renderQ() {
  const q = questions[current];
  document.getElementById('quizQuestion').textContent = `${current + 1}. ${q.q}`;
  const opts = document.getElementById('quizOptions');
  opts.innerHTML = '';
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-option';
    btn.textContent = opt;
    btn.onclick = () => answerQ(i);
    opts.appendChild(btn);
  });
  document.getElementById('quizFeedback').className = 'quiz-feedback';
  document.getElementById('nextBtn').disabled = true;
  document.getElementById('progressFill').style.width = `${(current / questions.length) * 100}%`;
  answered = false;
  updateScore();
}

function answerQ(i) {
  if (answered) return;
  answered = true;
  const q = questions[current];
  const btns = document.querySelectorAll('.quiz-option');
  btns.forEach(b => b.disabled = true);
  btns[q.correct].classList.add('correct');
  const fb = document.getElementById('quizFeedback');
  if (i === q.correct) {
    score++;
    btns[i].classList.add('correct');
    fb.className = 'quiz-feedback correct show';
    fb.textContent = '✓ Correcto! ' + q.exp;
  } else {
    btns[i].classList.add('wrong');
    fb.className = 'quiz-feedback wrong show';
    fb.textContent = '✗ Incorrecto. ' + q.exp;
  }
  document.getElementById('nextBtn').disabled = false;
  updateScore();
}

function updateScore() {
  document.getElementById('scoreLabel').textContent = `${score} / ${questions.length} correctas`;
}

document.getElementById('nextBtn').onclick = () => {
  current++;
  if (current < questions.length) {
    renderQ();
  } else {
    document.getElementById('progressFill').style.width = '100%';
    document.getElementById('quizCard').innerHTML = `
      <div style="text-align:center;padding:24px 0">
        <div style="font-size:44px;margin-bottom:14px">${score >= 9 ? '🏆' : score >= 7 ? '📚' : '💪'}</div>
        <div style="font-size:26px;font-weight:800;margin-bottom:8px;color:#e8eaf0">Resultado: ${score}/${questions.length}</div>
        <div style="color:#6b6b8a;margin-bottom:22px;font-size:14px">${score === 10 ? '¡Perfecto! Dominas los fundamentos web.' : score >= 7 ? 'Muy bien. Repasa los conceptos que fallaste.' : 'Sigue estudiando — revisa las secciones de arriba.'}</div>
        <button class="btn" onclick="location.reload()">Reintentar Quiz</button>
      </div>
    `;
  }
};

renderQ();
</script>