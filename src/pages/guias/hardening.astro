---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title="Hardening - CybSecStudy" description="Endurecimiento de sistemas, servicios, puertos y configuraciones explicado de forma visual e interactiva." />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    .guide-header { padding: 40px 0 32px; border-bottom: 1px solid #1e1e2e; margin-bottom: 32px; }
    .guide-tag { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 3px; color: #ff6b6b; margin-bottom: 16px; }
    h1 { font-size: clamp(28px, 5vw, 52px) !important; letter-spacing: -2px !important; margin-bottom: 16px !important; }
    .accent { color: #ff6b6b; }
    .intro-card { background: #12121a; border: 1px solid #1e1e2e; border-left: 3px solid #ff6b6b; padding: 20px 24px; margin-bottom: 40px; }
    .intro-card p { color: #b0b0c8; line-height: 1.8; font-size: 15px; margin: 0 0 8px; }
    .intro-card strong { color: #ff6b6b; }
    .section-label { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 3px; color: #6b6b8a; text-transform: uppercase; margin-bottom: 16px; }
    .concepts-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 48px; }
    .concept { background: #12121a; border: 1px solid #1e1e2e; cursor: pointer; transition: all 0.2s; overflow: hidden; }
    .concept:hover { border-color: var(--cc); transform: translateX(4px); }
    .concept.active { border-color: var(--cc) !important; }
    .concept-header { display: flex; align-items: center; }
    .concept-num { width: 56px; height: 52px; display: flex; align-items: center; justify-content: center; background: var(--cc); font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 11px; color: #000; flex-shrink: 0; }
    .concept-title { padding: 0 20px; font-weight: 800; font-size: 15px; color: var(--cc); }
    .concept-badge { margin-left: auto; margin-right: 16px; font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 4px 12px; border: 1px solid var(--cc); color: var(--cc); opacity: 0.6; white-space: nowrap; }
    .concept-body { display: none !important; padding: 20px 20px 20px 76px; border-top: 1px solid #1e1e2e; }
    .concept.active .concept-body { display: block !important; }
    .concept-body p, .concept-body li { font-size: 13px !important; color: #b0b0c8 !important; line-height: 1.8 !important; }
    .concept-body ul { padding: 0; list-style: none; display: flex; flex-direction: column; gap: 4px; margin-bottom: 10px; }
    .concept-body li::before { content: '> '; color: var(--cc); }
    .compare-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 8px; margin: 12px 0; }
    .compare-item { background: #0a0a0f; border: 1px solid #1e1e2e; padding: 12px 14px; }
    .compare-title { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700; color: var(--cc); margin-bottom: 6px; }
    .compare-desc { font-size: 11px; color: #6b6b8a; line-height: 1.5; }
    .code-block { background: #0a0a0f; border: 1px solid #1e1e2e; border-left: 2px solid var(--cc, #ff6b6b); padding: 12px 16px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #b0b0c8; line-height: 1.9; margin-top: 10px; white-space: pre; overflow-x: auto; }
    .info-badge { display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 9px; padding: 3px 8px; background: rgba(255,107,107,0.08); border: 1px solid #ff6b6b; color: #ff6b6b; margin-top: 8px; margin-right: 6px; }
    .sec-badge { display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 9px; padding: 3px 8px; background: rgba(77,150,255,0.06); border: 1px solid #4d96ff; color: #4d96ff; margin-top: 8px; margin-right: 6px; }
    .next-card { background: #12121a; border: 1px solid #1e1e2e; border-left: 3px solid #ff6b6b; padding: 20px 24px; margin-bottom: 48px; }
    .next-card strong { color: #ff6b6b; }
    .progress-bar { height: 2px; background: #1e1e2e; margin-bottom: 24px; }
    .progress-fill { height: 100%; background: #ff6b6b; transition: width 0.4s ease; }
    .quiz-card { background: #12121a; border: 1px solid #1e1e2e; padding: 28px; margin-bottom: 20px; }
    .quiz-question { font-size: 16px !important; font-weight: 600; margin-bottom: 20px; line-height: 1.5; color: #e8eaf0; }
    .quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
    .quiz-option { background: transparent; border: 1px solid #1e1e2e; color: #b0b0c8; padding: 12px 16px; cursor: pointer; font-family: 'Syne', sans-serif; font-size: 13px; text-align: left; transition: all 0.2s; }
    .quiz-option:hover { border-color: #ff6b6b; color: #ff6b6b; }
    .quiz-option.correct { border-color: #6bcb77 !important; background: rgba(107,203,119,0.08); color: #6bcb77 !important; }
    .quiz-option.wrong { border-color: #ff6b6b !important; background: rgba(255,107,107,0.08); color: #ff6b6b !important; }
    .quiz-feedback { display: none; font-size: 13px; padding: 10px 14px; border-left: 3px solid; margin-top: 10px; line-height: 1.6; }
    .quiz-feedback.show { display: block; }
    .quiz-feedback.correct { border-color: #6bcb77; color: #6bcb77; background: rgba(107,203,119,0.05); }
    .quiz-feedback.wrong { border-color: #ff6b6b; color: #b0b0c8; background: rgba(255,107,107,0.05); }
    .quiz-nav { display: flex; align-items: center; gap: 14px; margin-top: 8px; }
    .btn { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 1px; padding: 10px 20px; border: 1px solid #ff6b6b; background: transparent; color: #ff6b6b; cursor: pointer; transition: all 0.2s; text-transform: uppercase; }
    .btn:hover { background: #ff6b6b; color: #000; }
    .btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .btn:disabled:hover { background: transparent; color: #ff6b6b; }
    .score { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #6b6b8a; margin-left: auto; }
    @media (max-width: 640px) { .quiz-options { grid-template-columns: 1fr; } .concept-badge { display: none; } }
  </style>
</head>
<body>
  <Header />
  <main>
    <div class="guide-header">
      <div class="guide-tag">// Seguridad - Controles de Proteccion - Post 7</div>
      <h1><span class="accent">Hardening</span> de Sistemas y Servicios</h1>
      <p style="color:#6b6b8a;font-size:15px;max-width:660px">Endurecer significa reducir exposicion innecesaria, reforzar configuraciones y dejar menos puntos faciles de abuso.</p>
    </div>

    <div class="intro-card">
      <p>Hardening es la practica de <strong>quitar lo que sobra y reforzar lo que importa</strong>.</p>
      <p>No busca "hacerlo mas dificil porque si", sino dejar un entorno menos expuesto, menos permisivo y mas resistente.</p>
    </div>

    <div class="section-label">// Mapa visual</div>
    <img src="/hardening-pillars.svg" alt="Mapa de hardening" style="width:100%;margin-bottom:32px;border:none;border-radius:0" />

    <div class="section-label">// Conceptos clave - clic para expandir</div>
    <div class="concepts-list">
      <div class="concept" style="--cc:#ff6b6b">
        <div class="concept-header"><div class="concept-num">CORE</div><div class="concept-title">La idea central</div><div class="concept-badge">quitar y reforzar</div></div>
        <div class="concept-body"><p>Hardening consiste en reducir servicios, puertos, configuraciones y comportamientos innecesarios o demasiado abiertos.</p><div class="info-badge">Menos expuesto suele significar menos oportunidades de abuso.</div></div>
      </div>

      <div class="concept" style="--cc:#4d96ff">
        <div class="concept-header"><div class="concept-num">SCOPE</div><div class="concept-title">Donde aplica</div><div class="concept-badge">mucho mas que el SO</div></div>
        <div class="concept-body">
          <ul>
            <li>sistemas y endpoints</li>
            <li>servicios y puertos</li>
            <li>aplicaciones y paneles admin</li>
            <li>bases de datos</li>
            <li>cloud e identidades</li>
          </ul>
        </div>
      </div>

      <div class="concept" style="--cc:#6bcb77">
        <div class="concept-header"><div class="concept-num">SYS</div><div class="concept-title">Hardening de sistemas</div><div class="concept-badge">base mas segura</div></div>
        <div class="concept-body">
          <ul>
            <li>eliminar software innecesario</li>
            <li>desactivar cuentas y features sin uso</li>
            <li>endurecer login remoto</li>
            <li>deshabilitar protocolos inseguros</li>
            <li>reforzar auditoria y logs</li>
          </ul>
        </div>
      </div>

      <div class="concept" style="--cc:#ffd93d">
        <div class="concept-header"><div class="concept-num">NET</div><div class="concept-title">Servicios y puertos</div><div class="concept-badge">solo lo necesario</div></div>
        <div class="concept-body">
          <img src="/hardening-checklist.svg" alt="Checklist de hardening" style="width:100%;margin:10px 0;border:none;border-radius:0" />
          <ul>
            <li>cerrar puertos sobrantes</li>
            <li>bindear a localhost si procede</li>
            <li>limitar acceso admin por IP o VPN</li>
            <li>forzar TLS</li>
          </ul>
        </div>
      </div>

      <div class="concept" style="--cc:#c77dff">
        <div class="concept-header"><div class="concept-num">CFG</div><div class="concept-title">Defaults y configuracion</div><div class="concept-badge">comodidad vs seguridad</div></div>
        <div class="concept-body">
          <p>Muchas exposiciones reales nacen de defaults demasiado abiertos: debug activo, buckets publicos, paneles admin sin MFA o permisos laxos.</p>
          <div class="sec-badge">Hardening con criterio adapta baselines al contexto real.</div>
        </div>
      </div>

      <div class="concept" style="--cc:#00d1ff">
        <div class="concept-header"><div class="concept-num">FLOW</div><div class="concept-title">Como hacerlo bien</div><div class="concept-badge">sin romper a ciegas</div></div>
        <div class="concept-body">
          <div class="code-block">1. inventariar
2. revisar configuracion actual
3. detectar exposicion innecesaria
4. aplicar baseline
5. probar impacto
6. revisar periodicamente</div>
        </div>
      </div>

      <div class="concept" style="--cc:#ff9f43">
        <div class="concept-header"><div class="concept-num">ERR</div><div class="concept-title">Errores comunes</div><div class="concept-badge">mal hardening</div></div>
        <div class="concept-body">
          <img src="/hardening-before-after.svg" alt="Antes y despues del hardening" style="width:100%;margin:10px 0;border:none;border-radius:0" />
          <ul>
            <li>aplicar checklist sin contexto</li>
            <li>no probar cambios</li>
            <li>olvidar apps, cloud o identidades</li>
            <li>hacerlo una vez y no volver a revisar</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="next-card">
      <p style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:2px;color:#ff6b6b;margin-bottom:8px">// SEGURIDAD - CONTROLES DE PROTECCION</p>
      <p><strong>Siguiente sugerido:</strong> gestion de parches y vulnerabilidades para conectar endurecimiento con mantenimiento seguro continuo.</p>
    </div>

    <div class="section-label">// Quiz</div>
    <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
    <div class="quiz-card" id="quizCard">
      <div class="quiz-question" id="quizQuestion"></div>
      <div class="quiz-options" id="quizOptions"></div>
      <div class="quiz-feedback" id="quizFeedback"></div>
      <div class="quiz-nav">
        <button class="btn" id="nextBtn" disabled>Siguiente ></button>
        <span class="score" id="scoreLabel">0 / 0 correctas</span>
      </div>
    </div>
  </main>
  <Footer />
</body>
</html>

<script>
// @ts-nocheck
document.querySelectorAll('.concept').forEach(el => {
  el.addEventListener('click', () => {
    const was = el.classList.contains('active');
    document.querySelectorAll('.concept').forEach(x => x.classList.remove('active'));
    if (!was) el.classList.add('active');
  });
});
const questions = [
  { q: "Que es hardening?", opts: ["Solo cerrar puertos","Endurecer sistemas y configuraciones para reducir exposicion","Solo instalar antivirus","Solo parchear"], correct: 1, exp: "Hardening es endurecer configuracion y comportamiento para bajar exposicion." },
  { q: "Que describe mejor su filosofia?", opts: ["Abrir mas para facilitar soporte","Quitar, restringir y reforzar","Copiar defaults sin revisar","Dar mas permisos por comodidad"], correct: 1, exp: "La idea es reducir lo innecesario y reforzar lo importante." },
  { q: "En que puede aplicarse?", opts: ["Solo al SO","Solo a red","A sistemas, servicios, apps, cloud e identidades","Solo a bases de datos"], correct: 2, exp: "Es un control transversal." },
  { q: "Cual es una accion tipica de hardening?", opts: ["Mantener debug en produccion","Cerrar puertos sobrantes","Compartir cuentas admin","Abrir servicios legacy"], correct: 1, exp: "Cerrar puertos innecesarios es una accion clasica de endurecimiento." },
  { q: "Que problema tienen muchos defaults?", opts: ["Siempre son perfectos","Suelen priorizar facilidad y compatibilidad","Eliminan la necesidad de revisar","Nunca cambian"], correct: 1, exp: "Lo default no suele estar optimizado para tu riesgo concreto." },
  { q: "Que error es comun?", opts: ["Inventariar antes","Aplicar checklist sin contexto","Probar cambios","Revisar dependencias"], correct: 1, exp: "Sin contexto, el hardening puede ser inutil o romper cosas legitimas." },
  { q: "Que relacion tiene con minimo privilegio?", opts: ["Ninguna","Se refuerzan mutuamente","Lo sustituye","Lo contradice"], correct: 1, exp: "Uno reduce exposicion y el otro reduce alcance e impacto." },
  { q: "Que afirmacion es correcta?", opts: ["Hardening es puntual y ya","Hardening solo trata del kernel","Hardening debe revisarse periodicamente","Hardening significa bloquear todo"], correct: 2, exp: "Es una practica continua." },
  { q: "Que conviene hacer antes de endurecer?", opts: ["Cambiar sin revisar","Inventariar y entender dependencias","Desactivar todo","Ignorar impacto operativo"], correct: 1, exp: "Evita endurecer a ciegas." },
  { q: "Que resultado busca?", opts: ["Mas superficie y mas flexibilidad insegura","Menos exposicion y menos oportunidades de abuso","Mas puertos abiertos","Mas complejidad sin control"], correct: 1, exp: "Hardening busca bajar exposicion, no ampliarla." }
];
let current = 0, score = 0, answered = false;
function renderQ() {
  const q = questions[current];
  document.getElementById('quizQuestion').textContent = (current + 1) + '. ' + q.q;
  const opts = document.getElementById('quizOptions');
  opts.innerHTML = '';
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-option';
    btn.textContent = opt;
    btn.onclick = () => answerQ(i);
    opts.appendChild(btn);
  });
  document.getElementById('quizFeedback').className = 'quiz-feedback';
  document.getElementById('nextBtn').disabled = true;
  document.getElementById('progressFill').style.width = (current / questions.length * 100) + '%';
  answered = false;
  updateScore();
}
function answerQ(i) {
  if (answered) return;
  answered = true;
  const q = questions[current];
  const btns = document.querySelectorAll('.quiz-option');
  btns.forEach(b => b.disabled = true);
  btns[q.correct].classList.add('correct');
  const fb = document.getElementById('quizFeedback');
  if (i === q.correct) { score++; btns[i].classList.add('correct'); fb.className = 'quiz-feedback correct show'; fb.textContent = 'Correcto. ' + q.exp; }
  else { btns[i].classList.add('wrong'); fb.className = 'quiz-feedback wrong show'; fb.textContent = 'Incorrecto. ' + q.exp; }
  document.getElementById('nextBtn').disabled = false;
  updateScore();
}
function updateScore() { document.getElementById('scoreLabel').textContent = score + ' / ' + questions.length + ' correctas'; }
document.getElementById('nextBtn').onclick = () => {
  current++;
  if (current < questions.length) { renderQ(); }
  else {
    document.getElementById('progressFill').style.width = '100%';
    document.getElementById('quizCard').innerHTML = '<div style="text-align:center;padding:24px 0"><div style="font-size:44px;margin-bottom:14px">' + (score >= 9 ? 'A+' : score >= 7 ? 'OK' : 'REP') + '</div><div style="font-size:26px;font-weight:800;margin-bottom:8px;color:#e8eaf0">Resultado: ' + score + '/' + questions.length + '</div><div style="color:#6b6b8a;margin-bottom:22px;font-size:14px">' + (score === 10 ? 'Perfecto. Hardening ha quedado muy claro.' : score >= 7 ? 'Muy bien. Repasa defaults, baselines y alcance del hardening para afinar mas.' : 'Conviene revisar otra vez la relacion entre exposicion, configuracion y endurecimiento.') + '</div><button class="btn" onclick="location.reload()">Reintentar Quiz</button></div>';
  }
};
renderQ();
</script>
