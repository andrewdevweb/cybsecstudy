---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
}

// Map post IDs to categories — fallback when frontmatter category is missing
const slugCatMap: Record<string, string> = {
  'modelo-osi':        'redes',
  'packets-frames':    'redes',
  'ampliando-tu-red':  'redes',
  'ampliamos-tu-red':  'redes',
  'dns':               'redes',
  'http':              'web',
  'web':               'web',
  'infra':             'web',
  'clientserver':      'web',
  'computer':          'fundamentos',
  'comptypes':         'fundamentos',
  'os-intro':          'fundamentos',
  'virt':              'fundamentos',
  'cloud':             'fundamentos',
  'windows-basics':    'fundamentos',
  'linux-cli-intro':   'fundamentos',
  'linux-shell':       'fundamentos',
  'linux-fs':          'fundamentos',
  'linux-nav':         'fundamentos',
  'linux-files':       'fundamentos',
};

function getPostCategory(post: any): string {
  // Try frontmatter first, then slug-based map
  const fromFrontmatter = post.data?.category;
  if (fromFrontmatter) return fromFrontmatter;
  // post.id is like "linux-files.md" or "linux-files" in v4
  const slug = post.id.replace(/\.md$/, '').replace(/\.mdx$/, '');
  return slugCatMap[slug] ?? 'fundamentos';
}

const catMeta: Record<string, { label: string; color: string; desc: string }> = {
  fundamentos: { label: 'Fundamentos',  color: '#6bcb77', desc: 'Hardware, SO, virtualización y Linux' },
  redes:       { label: 'Redes',        color: '#4d96ff', desc: 'Protocolos, DNS, firewalls y VPNs' },
  web:         { label: 'Web',          color: '#ff6b9d', desc: 'HTTP, HTML, infraestructura web' },
};

const featured = allPosts[0];
const recent   = allPosts.slice(1, 4);
const rest     = allPosts.slice(4);

const catGroups = Object.entries(catMeta).map(([id, meta]) => ({
  id,
  ...meta,
  posts: allPosts.filter(p => getPostCategory(p) === id),
}));
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead title="Blog — CybSecStudy" description="Apuntes de ciberseguridad, redes y sistemas." />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
  <style>
    /* ── TOKENS ── */
    :root {
      --bg:      #0a0a0f;
      --surface: #12121a;
      --border:  #1e1e2e;
      --muted:   #6b6b8a;
      --dim:     #3a3a5a;
      --text:    #e8eaf0;
      --green:   #00ff9f;
    }

    /* ── HERO ── */
    .blog-hero {
      padding: 56px 0 48px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 56px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .hero-left {}
    .hero-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      letter-spacing: 4px;
      color: var(--green);
      text-transform: uppercase;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .hero-eyebrow::before {
      content: '';
      display: inline-block;
      width: 24px;
      height: 1px;
      background: var(--green);
    }
    .hero-title {
      font-size: clamp(40px, 6vw, 72px);
      font-weight: 800;
      letter-spacing: -3px;
      line-height: 0.95;
      color: var(--text);
      margin-bottom: 20px;
    }
    .hero-title em {
      font-style: normal;
      color: var(--green);
    }
    .hero-desc {
      font-size: 15px;
      color: var(--muted);
      line-height: 1.7;
      max-width: 400px;
      margin-bottom: 28px;
    }
    .hero-stats {
      display: flex;
      gap: 24px;
    }
    .hero-stat {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .hero-stat-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 26px;
      font-weight: 700;
      color: var(--text);
      line-height: 1;
    }
    .hero-stat-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px;
      letter-spacing: 2px;
      color: var(--dim);
    }
    .hero-right { display: flex; flex-direction: column; gap: 10px; }
    .hero-cat-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      border: 1px solid var(--border);
      background: var(--surface);
      text-decoration: none;
      transition: all 0.15s;
      cursor: pointer;
    }
    .hero-cat-row:hover { border-color: var(--hc); background: #161620; }
    .hero-cat-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--hc); flex-shrink: 0; }
    .hero-cat-name { font-weight: 800; font-size: 14px; color: var(--text); flex: 1; }
    .hero-cat-desc { font-size: 11px; color: var(--muted); }
    .hero-cat-count {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      padding: 3px 8px;
      background: var(--hc);
      color: #000;
      font-weight: 700;
      flex-shrink: 0;
    }

    /* ── SECTION LABEL ── */
    .section-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px;
      letter-spacing: 4px;
      color: var(--dim);
      text-transform: uppercase;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    /* ── FEATURED ── */
    .featured-section { margin-bottom: 64px; }
    .featured-card {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      border: 1px solid var(--border);
      text-decoration: none;
      overflow: hidden;
      transition: all 0.2s;
      background: var(--surface);
    }
    .featured-card:hover { border-color: var(--green); }
    .featured-card:hover .featured-img img { transform: scale(1.03); }
    .featured-img { overflow: hidden; background: var(--bg); border-right: 1px solid var(--border); }
    .featured-img img { width: 100%; height: 100%; object-fit: contain; display: block; transition: transform 0.4s ease; }
    .featured-body { padding: 36px 40px; display: flex; flex-direction: column; justify-content: space-between; }
    .featured-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px;
      letter-spacing: 2px;
      color: var(--green);
      border: 1px solid var(--green);
      padding: 5px 12px;
      width: fit-content;
      margin-bottom: 20px;
    }
    .featured-badge::before { content: '★'; font-size: 8px; }
    .featured-title {
      font-size: clamp(22px, 3vw, 32px);
      font-weight: 800;
      color: var(--text);
      line-height: 1.15;
      letter-spacing: -1px;
      margin-bottom: 16px;
    }
    .featured-desc { font-size: 14px; color: var(--muted); line-height: 1.7; margin-bottom: 28px; flex: 1; }
    .featured-meta { display: flex; align-items: center; gap: 16px; }
    .featured-date {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      color: var(--dim);
    }
    .featured-cat-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px;
      padding: 4px 10px;
      border: 1px solid var(--fc);
      color: var(--fc);
      letter-spacing: 1px;
    }
    .featured-read {
      margin-left: auto;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      color: var(--green);
      letter-spacing: 1px;
    }

    /* ── RECENT GRID ── */
    .recent-section { margin-bottom: 64px; }
    .recent-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }

    /* ── POST CARD ── */
    .post-card {
      background: var(--surface);
      border: 1px solid var(--border);
      text-decoration: none;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transition: all 0.15s;
      position: relative;
    }
    .post-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--pc, var(--green));
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.2s ease;
    }
    .post-card:hover { border-color: var(--pc, var(--green)); background: #161620; }
    .post-card:hover::after { transform: scaleX(1); }
    .post-card:hover .card-img img { transform: scale(1.04); }
    .card-img { overflow: hidden; background: var(--bg); border-bottom: 1px solid var(--border); }
    .card-img img { width: 100%; height: auto; object-fit: contain; display: block; transition: transform 0.35s ease; border: none; border-radius: 0; }
    .card-body { padding: 18px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .card-top { display: flex; align-items: center; gap: 8px; justify-content: space-between; }
    .card-cat {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px;
      letter-spacing: 1px;
      color: var(--pc, var(--green));
      text-transform: uppercase;
    }
    .card-date { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--dim); }
    .card-title { font-size: 15px; font-weight: 800; color: var(--text); line-height: 1.3; }
    .card-desc { font-size: 12px; color: var(--muted); line-height: 1.5; flex: 1; }
    .card-arrow { font-size: 11px; color: var(--dim); margin-top: 8px; text-align: right; transition: color 0.15s; }
    .post-card:hover .card-arrow { color: var(--pc, var(--green)); }

    /* ── FILTER BAR ── */
    .filter-section { margin-bottom: 48px; }
    .filter-bar { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 28px; }
    .filter-btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      letter-spacing: 1px;
      padding: 8px 16px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s;
      text-transform: uppercase;
    }
    .filter-btn:hover { border-color: var(--muted); color: var(--text); }
    .filter-btn.active { border-color: var(--green); color: var(--green); background: rgba(0,255,159,0.05); }

    /* ── ALL POSTS GRID ── */
    .all-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
    .post-item-hidden { display: none !important; }

    /* ── SEARCH ── */
    .search-wrap { position: relative; margin-bottom: 32px; }
    .search-input {
      width: 100%; background: var(--surface); border: 1px solid var(--border);
      border-left: 2px solid var(--green);
      color: var(--text); font-family: 'JetBrains Mono', monospace; font-size: 12px;
      padding: 13px 16px 13px 44px; outline: none; transition: border-color 0.2s; box-sizing: border-box;
    }
    .search-input:focus { border-color: var(--green); }
    .search-input::placeholder { color: var(--dim); }
    .search-ico { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--green); font-family: 'JetBrains Mono', monospace; font-size: 12px; pointer-events: none; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .blog-hero { grid-template-columns: 1fr; gap: 32px; }
      .featured-card { grid-template-columns: 1fr; }
      .featured-img { max-height: 200px; }
      .recent-grid { grid-template-columns: 1fr; }
      .all-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <Header />
  <main>

    <!-- ── HERO ── -->
    <div class="blog-hero">
      <div class="hero-left">
        <div class="hero-eyebrow">Apuntes públicos</div>
        <h1 class="hero-title">
          Cyber<em>Sec</em><br/>Study<br/>Blog
        </h1>
        <p class="hero-desc">
          Artículos técnicos sobre redes, sistemas y seguridad. Escritos mientras aprendo — pensados para que entiendas.
        </p>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-num">{allPosts.length}</span>
            <span class="hero-stat-label">artículos</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-num">{Object.keys(catMeta).length}</span>
            <span class="hero-stat-label">categorías</span>
          </div>
          <div class="hero-stat">
            <span class="hero-stat-num">
              {catGroups.reduce((max, c) => c.posts.length > max ? c.posts.length : max, 0)}
            </span>
            <span class="hero-stat-label">posts en cat. mayor</span>
          </div>
        </div>
      </div>

      <div class="hero-right">
        {catGroups.map(cat => (
          <div
            class="hero-cat-row"
            style={`--hc:${cat.color}`}
            onclick={`filterPosts('${cat.id}')`}
            role="button"
            tabindex="0"
          >
            <div class="hero-cat-dot"></div>
            <div class="hero-cat-name">{cat.label}</div>
            <div class="hero-cat-desc">{cat.desc}</div>
            <div class="hero-cat-count">{cat.posts.length}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── FEATURED ── -->
    {featured && (
      <div class="featured-section">
        <div class="section-label">Artículo destacado</div>
        <a
          href={`/blog/${featured.id}/`}
          class="featured-card"
          style={`--fc:${catMeta[getPostCategory(featured)]?.color ?? '#00ff9f'}`}
        >
          <div class="featured-img">
            {featured.data.heroImage
              ? <img src={featured.data.heroImage?.src ?? featured.data.heroImage} alt={featured.data.title} loading="eager"/>
              : <div style="width:100%;height:100%;min-height:260px;background:#12121a;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:11px;color:#3a3a5a">sin imagen</div>
            }
          </div>
          <div class="featured-body">
            <div>
              <div class="featured-badge">Más reciente</div>
              <div class="featured-title">{featured.data.title}</div>
              <div class="featured-desc">{featured.data.description}</div>
            </div>
            <div class="featured-meta">
              <span class="featured-date">{formatDate(featured.data.pubDate)}</span>
              <span class="featured-cat-tag">
                {catMeta[getPostCategory(featured)]?.label ?? 'General'}
              </span>
              <span class="featured-read">Leer →</span>
            </div>
          </div>
        </a>
      </div>
    )}

    <!-- ── RECIENTES ── -->
    {recent.length > 0 && (
      <div class="recent-section">
        <div class="section-label">Publicaciones recientes</div>
        <div class="recent-grid">
          {recent.map(post => {
            const cat = catMeta[getPostCategory(post)];
            const color = cat?.color ?? '#00ff9f';
            return (
              <a href={`/blog/${post.id}/`} class="post-card" style={`--pc:${color}`}>
                {post.data.heroImage && (
                  <div class="card-img">
                    <img src={post.data.heroImage?.src ?? post.data.heroImage} alt={post.data.title} loading="lazy"/>
                  </div>
                )}
                <div class="card-body">
                  <div class="card-top">
                    <span class="card-cat">{cat?.label ?? 'General'}</span>
                    <span class="card-date">{formatDate(post.data.pubDate)}</span>
                  </div>
                  <div class="card-title">{post.data.title}</div>
                  <div class="card-desc">{post.data.description}</div>
                  <div class="card-arrow">→</div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}

    <!-- ── TODOS LOS ARTÍCULOS ── -->
    <div class="filter-section">
      <div class="section-label">Todos los artículos</div>

      <div class="search-wrap">
        <span class="search-ico">//</span>
        <input
          class="search-input"
          type="text"
          id="searchInput"
          placeholder="Buscar por título, tema o categoría..."
          autocomplete="off"
        />
      </div>

      <div class="filter-bar" id="filterBar">
        <button class="filter-btn active" data-filter="all" onclick="filterPosts('all')">Todos</button>
        {catGroups.map(cat => (
          <button
            class="filter-btn"
            data-filter={cat.id}
            onclick={`filterPosts('${cat.id}')`}
            style={`--fc:${cat.color}`}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <div class="all-grid" id="allGrid">
        {allPosts.map(post => {
          const cat = catMeta[getPostCategory(post)];
          const color = cat?.color ?? '#00ff9f';
          const catId = getPostCategory(post) ?? 'general';
          return (
            <a
              href={`/blog/${post.id}/`}
              class="post-card"
              style={`--pc:${color}`}
              data-cat={catId}
              data-title={post.data.title.toLowerCase()}
              data-desc={(post.data.description ?? '').toLowerCase()}
            >
              {post.data.heroImage && (
                <div class="card-img">
                  <img src={post.data.heroImage?.src ?? post.data.heroImage} alt={post.data.title} loading="lazy"/>
                </div>
              )}
              <div class="card-body">
                <div class="card-top">
                  <span class="card-cat">{cat?.label ?? 'General'}</span>
                  <span class="card-date">{formatDate(post.data.pubDate)}</span>
                </div>
                <div class="card-title">{post.data.title}</div>
                <div class="card-desc">{post.data.description}</div>
                <div class="card-arrow">→</div>
              </div>
            </a>
          );
        })}
      </div>
    </div>

  </main>
  <Footer />
</body>
</html>

<script>
// @ts-nocheck
let activeFilter = 'all';
let searchQuery = '';

function filterPosts(cat) {
  activeFilter = cat;

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.filter === cat);
  });

  if (cat !== 'all') {
    setTimeout(() => {
      document.getElementById('allGrid').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 50);
  }

  applyFilters();
}

function applyFilters() {
  const cards = document.querySelectorAll('#allGrid .post-card');
  cards.forEach(card => {
    const cardCat = (card.getAttribute('data-cat') || '').trim();
    const cardTitle = (card.getAttribute('data-title') || '').trim();
    const cardDesc = (card.getAttribute('data-desc') || '').trim();

    const matchCat = activeFilter === 'all' || cardCat === activeFilter;
    const matchSearch = searchQuery === '' ||
      cardTitle.includes(searchQuery) ||
      cardDesc.includes(searchQuery) ||
      cardCat.includes(searchQuery);

    card.classList.toggle('post-item-hidden', !(matchCat && matchSearch));
  });
}

document.getElementById('searchInput').addEventListener('input', (e) => {
  searchQuery = e.target.value.trim().toLowerCase();
  applyFilters();
});

window.filterPosts = filterPosts;
</script>