---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

function formatDate(date : Date) {
  return new Date(date).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
}

const guides = [
  { num: '01', href: '/guias/modelo-osi',       title: 'Modelo OSI',        desc: 'Las 7 capas explicadas con protocolos y quiz interactivo.',          tag: 'Redes', color: '#00ff9f' },
  { num: '02', href: '/guias/packets-frames',   title: 'Packets & Frames',  desc: 'TCP, UDP, Three-Way Handshake y puertos principales.',               tag: 'Redes', color: '#4d96ff' },
  { num: '03', href: '/guias/ampliando-tu-red', title: 'Ampliando tu Red',  desc: 'Port Forwarding, Firewalls, VPNs, Routers y Switches.',              tag: 'Redes', color: '#ff9f43' },
  { num: '04', href: '/guias/dns',              title: 'DNS',               desc: 'Sistema de Nombres de Dominio — jerarquía, registros y resolución.', tag: 'Redes', color: '#c77dff' },
  { num: '05', href: '/guias/http',             title: 'HTTP en Detalle',   desc: 'Solicitudes, respuestas, métodos, códigos de estado y cookies.',      tag: 'Web',   color: '#ff6b9d' },
  { num: '06', href: '/guias/web',              title: 'Sitios Web',        desc: 'HTML, CSS, JavaScript, exposición de datos y HTML Injection.',         tag: 'Web',   color: '#6bcb77' },
  { num: '07', href: '/guias/infra',            title: 'La Web por Dentro', desc: 'Balanceadores, CDN, WAF, bases de datos y servidores web.',             tag: 'Web',          color: '#ff9f43' },
  { num: '08', href: '/guias/computer',         title: 'Sistema Informático', desc: 'CPU, RAM, almacenamiento, GPU y secuencia de arranque.',              tag: 'Fundamentos',  color: '#00ff9f' },
  { num: '09', href: '/guias/comptypes',        title: 'Tipos de Computadoras', desc: 'Portátiles, servidores, IoT, sistemas embebidos y smartphones.',    tag: 'Fundamentos',  color: '#6bcb77' },
  { num: '10', href: '/guias/clientserver',     title: 'Cliente-Servidor',    desc: 'Cliente, servidor, DNS, puertos, protocolos y HTTP.',                tag: 'Fundamentos',  color: '#4d96ff' },
  { num: '11', href: '/guias/virt',             title: 'Virtualización',      desc: 'Hipervisores Tipo 1 y 2, máquinas virtuales y contenedores Docker.',  tag: 'Fundamentos',  color: '#c77dff' },
  { num: '12', href: '/guias/cloud',            title: 'Cloud Computing',     desc: 'IaaS, PaaS, SaaS, AWS, proveedores y seguridad en la nube.',          tag: 'Fundamentos',  color: '#4d96ff' },
  { num: '13', href: '/guias/os-intro',         title: 'Sistemas Operativos', desc: 'Kernel, privilegios, tipos de SO, Linux, Windows y CLI vs GUI.',       tag: 'Fundamentos',  color: '#6bcb77' },
  { num: '14', href: '/guias/windows-basics',   title: 'Windows Básico',        desc: 'Autenticación, registro, administrador de tareas y seguridad nativa.',  tag: 'Fundamentos',  color: '#4d96ff' },
  { num: '15', href: '/guias/linux-cli-intro',  title: 'Linux — Intro CLI',        desc: 'Qué es Linux, filosofía Unix, CLI vs GUI y el poder de la terminal.',   tag: 'Fundamentos',  color: '#00ff9f' },
  { num: '16', href: '/guias/linux-shell',      title: 'Terminal, Consola y Shell', desc: 'Diferencias entre terminal, consola y shell. Bash, zsh, $PATH.',        tag: 'Fundamentos',  color: '#00ff9f' },
  { num: '17', href: '/guias/linux-fs',         title: 'Sistema de Archivos Linux', desc: 'Jerarquía FHS, /etc, /home, /var, /proc, rutas e inodes.',              tag: 'Fundamentos',  color: '#00ff9f' },
];
const recentGuides = guides.slice(-3).reverse();
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-tag">// aprendizaje público</div>
				<h1>Apuntes de<br/><span class="accent">Ciberseguridad</span><br/>& Redes</h1>
				<p class="hero-desc">Documentando todo lo que aprendo sobre redes, seguridad y sistemas. Guías interactivas, apuntes y cheatsheets.</p>
				<div class="hero-links">
					<a href="/blog" class="btn-primary">Ver apuntes →</a>
					<a href="/guias" class="btn-secondary">Guías interactivas</a>
				</div>
			</section>

			<section class="section">
				<div class="section-label">// últimos apuntes</div>
				<div class="posts-grid">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							<div class="post-image">
								{post.data.heroImage
									? <img src={post.data.heroImage.src ?? post.data.heroImage} alt={post.data.title} />
									: <div class="post-image-placeholder" />
								}
							</div>
							<div class="post-body">
								<div class="post-date">{formatDate(post.data.pubDate)}</div>
								<div class="post-title">{post.data.title}</div>
								<div class="post-desc">{post.data.description}</div>
							</div>
						</a>
					))}
				</div>
				<div style="margin-top: 24px;">
					<a href="/blog" class="btn-secondary">Ver todos los apuntes →</a>
				</div>
			</section>

			<section class="section">
				<div class="section-label">// guías interactivas</div>
				<div class="cards">
					{recentGuides.map((g) => (
						<a href={g.href} class="card" style={`--cc:${g.color}`}>
							<div class="card-num" style={`color:${g.color}`}>{g.num}</div>
							<div class="card-body">
								<div class="card-title">{g.title}</div>
								<div class="card-desc">{g.desc}</div>
								<div class="card-tag" style={`color:${g.color};border-color:${g.color}`}>{g.tag}</div>
							</div>
						</a>
					))}
				</div>
				<div style="margin-top: 24px;">
					<a href="/guias" class="btn-secondary">Ver todas las guías →</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 60px 0 80px;
		border-bottom: 1px solid #1e1e2e;
		margin-bottom: 60px;
	}
	.hero-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 12px;
		letter-spacing: 2px;
		color: #00ff9f;
		margin-bottom: 24px;
	}
	h1 {
		font-size: clamp(36px, 7vw, 64px);
		line-height: 1.05;
		margin-bottom: 24px;
		letter-spacing: -2px;
	}
	.accent { color: #00ff9f; }
	.hero-desc {
		color: #6b6b8a;
		font-size: 16px;
		max-width: 480px;
		margin-bottom: 32px;
		line-height: 1.7;
	}
	.hero-links { display: flex; gap: 12px; flex-wrap: wrap; }
	.btn-primary {
		font-family: 'JetBrains Mono', monospace;
		font-size: 13px;
		letter-spacing: 1px;
		padding: 12px 24px;
		background: #00ff9f;
		color: #000;
		text-decoration: none;
		border: none;
		font-weight: 700;
		transition: opacity 0.2s;
	}
	.btn-primary:hover { opacity: 0.85; border-bottom: none; }
	.btn-secondary {
		font-family: 'JetBrains Mono', monospace;
		font-size: 13px;
		letter-spacing: 1px;
		padding: 12px 24px;
		background: transparent;
		color: #00ff9f;
		text-decoration: none;
		border: 1px solid #00ff9f;
		transition: all 0.2s;
		display: inline-block;
	}
	.btn-secondary:hover { background: rgba(0,255,159,0.08); border-bottom-color: #00ff9f; }
	.section { margin-bottom: 60px; }
	.section-label {
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		letter-spacing: 3px;
		color: #6b6b8a;
		text-transform: uppercase;
		margin-bottom: 24px;
	}
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 16px;
	}
	.post-card {
		background: #12121a;
		border: 1px solid #1e1e2e;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		transition: all 0.2s;
		overflow: hidden;
	}
	.post-card:hover { border-color: #00ff9f; transform: translateY(-2px); }
	.post-image {
		width: 100%;
		overflow: hidden;
		border-bottom: 1px solid #1e1e2e;
		background: #0a0a0f;
	}
	.post-image img {
		width: 100%;
		height: auto;
		object-fit: contain;
		border-radius: 0;
		border: none;
		transition: transform 0.3s ease;
	}
	.post-image-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #12121a 0%, #1e1e2e 100%);
	}
	.post-card:hover .post-image img { transform: scale(1.03); }
	.post-body { padding: 20px; display: flex; flex-direction: column; gap: 8px; }
	.post-date {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		letter-spacing: 1px;
		color: #6b6b8a;
		text-transform: uppercase;
	}
	.post-title { font-size: 16px; font-weight: 800; color: #e8eaf0; line-height: 1.3; }
	.post-desc { font-size: 13px; color: #6b6b8a; line-height: 1.5; }
	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 12px;
	}
	.card {
		background: #12121a;
		border: 1px solid #1e1e2e;
		padding: 24px;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		gap: 12px;
		transition: all 0.2s;
		cursor: pointer;
	}
	.card:hover { border-color: var(--cc); transform: translateY(-2px); }
	.card-num {
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		letter-spacing: 2px;
	}
	.card-title { font-size: 17px; font-weight: 800; color: #e8eaf0; margin-bottom: 6px; }
	.card-desc { font-size: 13px; color: #6b6b8a; line-height: 1.5; }
	.card-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		letter-spacing: 1px;
		padding: 2px 8px;
		display: inline-block;
		margin-top: 8px;
	}
	@media (max-width: 640px) {
		.posts-grid { grid-template-columns: 1fr; }
		.cards { grid-template-columns: 1fr; }
	}
</style>