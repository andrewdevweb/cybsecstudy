---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-tag">// aprendizaje público</div>
				<h1>Apuntes de<br/><span class="accent">Ciberseguridad</span><br/>& Redes</h1>
				<p class="hero-desc">Documentando todo lo que aprendo sobre redes, seguridad y sistemas. Guías interactivas, apuntes y cheatsheets.</p>
				<div class="hero-links">
					<a href="/blog" class="btn-primary">Ver apuntes →</a>
					<a href="/guias" class="btn-secondary">Guías interactivas</a>
				</div>
			</section>

			<!-- APUNTES -->
			<section class="section">
				<div class="section-label">// últimos apuntes</div>
				<div class="posts-grid">
					<a href="/blog/packets-frames" class="post-card">
						<div class="post-image">
							<img src="/src/assets/packets-hero.svg" alt="Packets & Frames" />
						</div>
						<div class="post-body">
							<div class="post-date">06 mar 2025</div>
							<div class="post-title">Packets & Frames — TCP, UDP y Puertos</div>
							<div class="post-desc">Paquetes, tramas, TCP vs UDP, el Three-Way Handshake y los puertos más importantes.</div>
						</div>
					</a>
					<a href="/blog/modelo-osi" class="post-card">
						<div class="post-image">
							<img src="/src/assets/osi-hero.svg" alt="Modelo OSI" />
						</div>
						<div class="post-body">
							<div class="post-date">06 mar 2025</div>
							<div class="post-title">Modelo OSI — Las 7 Capas</div>
							<div class="post-desc">Guía completa del Modelo de Interconexión de Sistemas Abiertos: capas, protocolos y encapsulación.</div>
						</div>
					</a>
				</div>
				<div style="margin-top: 24px;">
					<a href="/blog" class="btn-secondary">Ver todos los apuntes →</a>
				</div>
			</section>

			<!-- GUÍAS -->
			<section class="section">
				<div class="section-label">// guías interactivas</div>
				<div class="cards">
					<a href="/guias/modelo-osi" class="card">
						<div class="card-num">01</div>
						<div class="card-body">
							<div class="card-title">Modelo OSI</div>
							<div class="card-desc">Las 7 capas explicadas con ejemplos, protocolos y quiz interactivo.</div>
							<div class="card-tag">Redes</div>
						</div>
					</a>
					<a href="/guias/packets-frames" class="card">
						<div class="card-num">02</div>
						<div class="card-body">
							<div class="card-title">Packets & Frames</div>
							<div class="card-desc">TCP, UDP, Three-Way Handshake y puertos principales.</div>
							<div class="card-tag">Redes</div>
						</div>
					</a>
					<div class="card card-soon">
						<div class="card-num">03</div>
						<div class="card-body">
							<div class="card-title">Subnetting</div>
							<div class="card-desc">Próximamente...</div>
							<div class="card-tag">Redes</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 60px 0 80px;
		border-bottom: 1px solid #1e1e2e;
		margin-bottom: 60px;
	}

	.hero-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 12px;
		letter-spacing: 2px;
		color: #00ff9f;
		margin-bottom: 24px;
	}

	h1 {
		font-size: clamp(36px, 7vw, 64px);
		line-height: 1.05;
		margin-bottom: 24px;
		letter-spacing: -2px;
	}

	.accent { color: #00ff9f; }

	.hero-desc {
		color: #6b6b8a;
		font-size: 16px;
		max-width: 480px;
		margin-bottom: 32px;
		line-height: 1.7;
	}

	.hero-links {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
	}

	.btn-primary {
		font-family: 'JetBrains Mono', monospace;
		font-size: 13px;
		letter-spacing: 1px;
		padding: 12px 24px;
		background: #00ff9f;
		color: #000;
		text-decoration: none;
		border: none;
		font-weight: 700;
		transition: opacity 0.2s;
	}

	.btn-primary:hover { opacity: 0.85; border-bottom: none; }

	.btn-secondary {
		font-family: 'JetBrains Mono', monospace;
		font-size: 13px;
		letter-spacing: 1px;
		padding: 12px 24px;
		background: transparent;
		color: #00ff9f;
		text-decoration: none;
		border: 1px solid #00ff9f;
		transition: all 0.2s;
		display: inline-block;
	}

	.btn-secondary:hover { background: rgba(0,255,159,0.08); border-bottom-color: #00ff9f; }

	.section { margin-bottom: 60px; }

	.section-label {
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		letter-spacing: 3px;
		color: #6b6b8a;
		text-transform: uppercase;
		margin-bottom: 24px;
	}

	/* POSTS */
	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 16px;
	}

	.post-card {
		background: #12121a;
		border: 1px solid #1e1e2e;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		transition: all 0.2s;
		overflow: hidden;
	}

	.post-card:hover {
		border-color: #00ff9f;
		transform: translateY(-2px);
	}

	.post-image {
		width: 100%;
		height: 160px;
		overflow: hidden;
		border-bottom: 1px solid #1e1e2e;
		background: #0a0a0f;
	}

	.post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		border: none;
		transition: transform 0.3s ease;
	}

	.post-card:hover .post-image img { transform: scale(1.03); }

	.post-body {
		padding: 20px;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.post-date {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		letter-spacing: 1px;
		color: #6b6b8a;
		text-transform: uppercase;
	}

	.post-title {
		font-size: 16px;
		font-weight: 800;
		color: #e8eaf0;
		line-height: 1.3;
	}

	.post-desc {
		font-size: 13px;
		color: #6b6b8a;
		line-height: 1.5;
	}

	/* GUÍAS */
	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 12px;
	}

	.card {
		background: #12121a;
		border: 1px solid #1e1e2e;
		padding: 24px;
		text-decoration: none;
		display: flex;
		flex-direction: column;
		gap: 12px;
		transition: all 0.2s;
		cursor: pointer;
	}

	.card:hover {
		border-color: #00ff9f;
		transform: translateY(-2px);
	}

	.card-soon {
		opacity: 0.4;
		cursor: default;
	}

	.card-soon:hover {
		border-color: #1e1e2e;
		transform: none;
	}

	.card-num {
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		color: #00ff9f;
		letter-spacing: 2px;
	}

	.card-title {
		font-size: 17px;
		font-weight: 800;
		color: #e8eaf0;
		margin-bottom: 6px;
	}

	.card-desc {
		font-size: 13px;
		color: #6b6b8a;
		line-height: 1.5;
	}

	.card-tag {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		letter-spacing: 1px;
		color: #00ff9f;
		border: 1px solid #00ff9f;
		padding: 2px 8px;
		display: inline-block;
		margin-top: 8px;
	}

	@media (max-width: 640px) {
		.posts-grid { grid-template-columns: 1fr; }
		.cards { grid-template-columns: 1fr; }
	}
</style>
